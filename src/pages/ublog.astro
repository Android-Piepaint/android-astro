---
// src/pages/ublog.astro
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

// 直接讀取 src/content/spec/random.md
const entry = await getEntry("spec", "random");

// 保險機制：如果找不到檔案則重新導向
if (!entry) {
	return Astro.redirect("/");
}

const { Content } = await render(entry);
---

<MainGridLayout title="動態牆" description="我的個人動態牆">
    <div class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full">
        <Markdown class="mb-6 markdown-content">
            <Content />
        </Markdown>
    </div>
</MainGridLayout>